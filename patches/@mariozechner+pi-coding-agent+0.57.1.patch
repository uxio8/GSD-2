+import { createHash } from "node:crypto";
+import { accessSync, existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
+import { join } from "node:path";
+
+const BLOB_PREFIX = "blob:sha256:";
+const SHA256_HEX_RE = /^[a-f0-9]{64}$/;
+
+export class BlobStore {
+    dir;
+    constructor(dir) {
+        this.dir = dir;
+        mkdirSync(dir, { recursive: true });
+    }
+    put(data) {
+        const hash = createHash("sha256").update(data).digest("hex");
+        const blobPath = join(this.dir, hash);
+        const result = {
+            hash,
+            path: blobPath,
+            get ref() {
+                return `${BLOB_PREFIX}${hash}`;
+            },
+        };
+        if (!existsSync(blobPath)) {
+            writeFileSync(blobPath, data);
+        }
+        return result;
+    }
+    get(hash) {
+        if (!SHA256_HEX_RE.test(hash))
+            return null;
+        try {
+            return readFileSync(join(this.dir, hash));
+        }
+        catch {
+            return null;
+        }
+    }
+    has(hash) {
+        if (!SHA256_HEX_RE.test(hash))
+            return false;
+        try {
+            accessSync(join(this.dir, hash));
+            return true;
+        }
+        catch {
+            return false;
+        }
+    }
+}
+export function isBlobRef(data) {
+    return data.startsWith(BLOB_PREFIX);
+}
+export function parseBlobRef(data) {
+    if (!data.startsWith(BLOB_PREFIX))
+        return null;
+    const hash = data.slice(BLOB_PREFIX.length);
+    return SHA256_HEX_RE.test(hash) ? hash : null;
+}
+export function externalizeImageData(blobStore, base64Data) {
+    if (isBlobRef(base64Data))
+        return base64Data;
+    const buffer = Buffer.from(base64Data, "base64");
+    return blobStore.put(buffer).ref;
+}
+export function resolveImageData(blobStore, data) {
+    const hash = parseBlobRef(data);
+    if (!hash)
+        return data;
+    const buffer = blobStore.get(hash);
+    return buffer ? buffer.toString("base64") : data;
+}
