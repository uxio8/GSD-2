new file mode 100644
index 0000000..c4ebbd2
--- /dev/null
+++ b/node_modules/@mariozechner/pi-coding-agent/dist/core/artifact-manager.js
@@ -0,0 +1,67 @@
+import { mkdirSync, readdirSync, writeFileSync } from "node:fs";
+import { join } from "node:path";
+
+export class ArtifactManager {
+    #nextId = 0;
+    #dirCreated = false;
+    #initialized = false;
+    #dir;
+    constructor(sessionFile) {
+        this.#dir = sessionFile.slice(0, -6);
+    }
+    get dir() {
+        return this.#dir;
+    }
+    #ensureDir() {
+        if (!this.#dirCreated) {
+            mkdirSync(this.#dir, { recursive: true });
+            this.#dirCreated = true;
+        }
+        if (!this.#initialized) {
+            this.#scanExistingIds();
+            this.#initialized = true;
+        }
+    }
+    #scanExistingIds() {
+        const files = this.listFiles();
+        let maxId = -1;
+        for (const file of files) {
+            const match = file.match(/^(\d+)\..*\.log$/);
+            if (!match)
+                continue;
+            const id = parseInt(match[1], 10);
+            if (id > maxId)
+                maxId = id;
+        }
+        this.#nextId = maxId + 1;
+    }
+    allocateId() {
+        return this.#nextId++;
+    }
+    allocatePath(toolType) {
+        this.#ensureDir();
+        const id = String(this.allocateId());
+        const filename = `${id}.${toolType}.log`;
+        return { id, path: join(this.#dir, filename) };
+    }
+    save(content, toolType) {
+        const { id, path } = this.allocatePath(toolType);
+        writeFileSync(path, content);
+        return id;
+    }
+    exists(id) {
+        return this.listFiles().some((file) => file.startsWith(`${id}.`));
+    }
+    listFiles() {
+        try {
+            return readdirSync(this.#dir);
+        }
+        catch {
+            return [];
+        }
+    }
+    getPath(id) {
+        const match = this.listFiles().find((file) => file.startsWith(`${id}.`));
+        return match ? join(this.#dir, match) : null;
+    }
+}
